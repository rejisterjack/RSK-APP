generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model User {
  id                String                @id @default(cuid())
  name              String?
  email             String                @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              UserRole              @default(USER)
  activeWorkspaceId String?
  samlId            String?               @unique
  mfaEnabled        Boolean               @default(false)
  mfaSecret         String?
  mfaBackupCodes    String[]              @default([])
  mfaVerifiedAt     DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  accounts          Account[]
  createdApiKeys    ApiKey[]
  apiUsage          ApiUsage[]
  auditLogs         AuditLog[]
  chats             Chat[]
  consents          Consent[]
  documents         Document[]
  feedback          MessageFeedback[]
  rateLimits        RateLimit[]
  sessions          Session[]
  invitationsSent   WorkspaceInvitation[] @relation("InvitationSender")
  workspaceMembers  WorkspaceMember[]
  ownedWorkspaces   Workspace[]           @relation("WorkspaceOwner")

  @@index([samlId])
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Workspace {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  description    String?
  logoUrl        String?
  ssoEnabled     Boolean               @default(false)
  ssoDomain      String?
  settings       Json                  @default("{}")
  maxDocuments   Int                   @default(100)
  maxStorageMb   Int                   @default(1024)
  maxChats       Int                   @default(1000)
  maxChatPerDay  Int                   @default(50)
  llmProvider    String?
  llmModel       String?
  ownerId        String
  version        Int                   @default(1)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  chats          Chat[]
  collections    DocumentCollection[]
  tags           DocumentTag[]
  documents      Document[]
  samlConnection SamlConnection?
  invitations    WorkspaceInvitation[]
  members        WorkspaceMember[]
  owner          User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  status      MemberStatus  @default(ACTIVE)
  joinedAt    DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id            String        @id @default(cuid())
  workspaceId   String
  email         String
  role          WorkspaceRole @default(MEMBER)
  status        InviteStatus  @default(PENDING)
  token         String        @unique
  expiresAt     DateTime
  invitedById   String
  invitedAt     DateTime      @default(now())
  acceptedAt    DateTime?
  cancelledAt   DateTime?
  cancelledById String?
  invitedBy     User          @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("workspace_invitations")
}

model Document {
  id                  String                           @id @default(cuid())
  name                String
  contentType         String
  size                Int
  content             String?
  sourceUrl           String?
  sourceType          String?
  metadata            Json                             @default("{}")
  contentHash         String?                          @unique
  status              DocumentStatus                   @default(PENDING)
  /// /** Whether OCR was applied to this document
  ocrProcessed        Boolean                          @default(false)
  /// * OCR confidence score (0-100)
  ocrConfidence       Float?
  /// * OCR language code used (e.g., 'eng', 'deu')
  ocrLanguage         String?
  /// * OCR processing time in milliseconds
  ocrProcessingTimeMs Int?
  /// * OCR engine mode used
  ocrEngineMode       String?
  /// * Page segmentation mode used
  ocrPSM              String?
  /// * Whether preprocessing was applied
  ocrPreprocessing    Boolean                          @default(false)
  /// * Error message if OCR failed
  ocrError            String?
  userId              String
  workspaceId         String?
  chunkCount          Int                              @default(0)
  version             Int                              @default(1)
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
  storageKey          String?
  storageUrl          String?
  collections         DocumentCollectionsOnDocuments[]
  images              DocumentImage[]
  tags                DocumentTagsOnDocuments[]
  user                User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace?                       @relation(fields: [workspaceId], references: [id])
  ingestionJob        IngestionJob?

  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([ocrProcessed])
  @@index([ocrConfidence])
  @@map("documents")
}

model IngestionJob {
  id            String         @id @default(cuid())
  documentId    String         @unique
  status        JobStatus      @default(QUEUED)
  progress      Int            @default(0)
  error         String?
  errorCategory ErrorCategory?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  document      Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ingestion_jobs")
}

model DocumentImage {
  id                  String         @id @default(cuid())
  documentId          String
  filename            String
  mimeType            String
  size                Int
  width               Int?
  height              Int?
  storageKey          String
  storageUrl          String
  caption             String?
  ocrText             String?
  /// /** OCR confidence score (0-100)
  ocrConfidence       Float?
  /// * OCR language code used
  ocrLanguage         String?
  /// * OCR processing time in milliseconds
  ocrProcessingTimeMs Int?
  /// * Whether OCR preprocessing was applied
  ocrPreprocessing    Boolean        @default(false)
  /// * OCR bounding boxes as JSON
  ocrBoundingBoxes    Json?
  chunkId             String?
  pageNumber          Int?
  status              ImageStatus    @default(PENDING)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  document            Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
  @@index([ocrConfidence])
  @@map("document_images")
}

model Chat {
  id          String     @id @default(cuid())
  title       String     @default("New Chat")
  model       String?
  metadata    Json?      @default("{}")
  chunkCount  Int?
  userId      String
  workspaceId String?
  version     Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  share       ChatShare?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  messages    Message[]

  @@index([userId])
  @@index([workspaceId])
  @@index([userId, workspaceId])
  @@index([userId, updatedAt])
  @@map("chats")
}

model Message {
  id         String            @id @default(cuid())
  chatId     String
  content    String
  role       MessageRole
  sources    Json?
  tokensUsed Json?
  metadata   Json?
  createdAt  DateTime          @default(now())
  feedback   MessageFeedback[]
  chat       Chat              @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([chatId, createdAt])
  @@map("messages")
}

model MessageFeedback {
  id         String         @id @default(cuid())
  messageId  String
  rating     FeedbackRating
  comment    String?
  categories String[]       @default([])
  userId     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  message    Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User?          @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@map("message_feedback")
}

model ChatShare {
  id            String    @id @default(cuid())
  chatId        String    @unique
  isPublic      Boolean   @default(false)
  shareToken    String    @unique @default(cuid())
  allowComments Boolean   @default(false)
  expiresAt     DateTime?
  viewCount     Int       @default(0)
  lastViewedAt  DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  chat          Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([shareToken])
  @@index([isPublic])
  @@index([expiresAt])
  @@map("chat_shares")
}

model DocumentTag {
  id          String                    @id @default(cuid())
  name        String
  color       String                    @default("#6366f1")
  workspaceId String
  createdAt   DateTime                  @default(now())
  workspace   Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   DocumentTagsOnDocuments[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("document_tags")
}

model DocumentTagsOnDocuments {
  documentId String
  tagId      String
  assignedAt DateTime    @default(now())
  assignedBy String?
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        DocumentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tags_on_documents")
}

model DocumentCollection {
  id          String                           @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  workspace   Workspace                        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   DocumentCollectionsOnDocuments[]

  @@index([workspaceId])
  @@map("document_collections")
}

model DocumentCollectionsOnDocuments {
  documentId   String
  collectionId String
  addedAt      DateTime           @default(now())
  addedBy      String?
  order        Int                @default(0)
  collection   DocumentCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  document     Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([documentId, collectionId])
  @@index([collectionId])
  @@map("document_collections_on_documents")
}

model ApiKey {
  id               String       @id @default(cuid())
  name             String
  keyHash          String       @unique
  keyPreview       String
  permissions      String[]     @default([])
  allowedIps       String[]     @default([])
  allowedEndpoints String[]     @default([])
  status           ApiKeyStatus @default(ACTIVE)
  expiresAt        DateTime?
  lastUsedAt       DateTime?
  rateLimit        Int          @default(100)
  userId           String
  workspaceId      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace?   @relation(fields: [workspaceId], references: [id])
  usage            ApiUsage[]

  @@index([userId])
  @@index([workspaceId])
  @@index([keyHash])
  @@map("api_keys")
}

model ApiUsage {
  id               String   @id @default(cuid())
  endpoint         String
  method           String
  tokensPrompt     Int      @default(0)
  tokensCompletion Int      @default(0)
  tokensTotal      Int      @default(0)
  latencyMs        Int      @default(0)
  apiKeyId         String?
  userId           String?
  workspaceId      String?
  createdAt        DateTime @default(now())
  apiKey           ApiKey?  @relation(fields: [apiKeyId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])

  @@index([apiKeyId])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
  @@map("api_usage")
}

model AuditLog {
  id           String        @id @default(cuid())
  event        AuditEvent
  severity     AuditSeverity @default(INFO)
  userId       String?
  workspaceId  String?
  metadata     Json?
  resource     Json?
  changes      Json?
  error        String?
  ipAddress    String?
  userAgent    String?
  recordHash   String?
  previousHash String?
  createdAt    DateTime      @default(now())
  user         User?         @relation(fields: [userId], references: [id])
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([event])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
  @@index([event, createdAt])
  @@map("audit_logs")
}

model RateLimit {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  requests    Int      @default(0)
  type        String   @default("default")
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, type, windowStart])
  @@index([key])
  @@index([userId])
  @@index([windowStart])
  @@map("rate_limits")
}

model SystemHealth {
  id        String    @id @default(cuid())
  feature   String    @unique
  status    String    @default("healthy")
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  @@map("system_health")
}

model RAGEvent {
  id                  String           @id @default(cuid())
  query               String
  conversationId      String?
  workspaceId         String?
  userId              String?
  retrievedChunksData Json?            @map("retrievedChunks")
  response            String?
  latencyMs           Int
  totalTokens         Int              @default(0)
  model               String           @default("gpt-4o-mini")
  queryType           String?
  confidence          Float?
  reranked            Boolean          @default(false)
  createdAt           DateTime         @default(now())
  retrievedChunks     RetrievedChunk[]

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@map("rag_events")
}

model RetrievedChunk {
  id         String   @id @default(cuid())
  eventId    String
  chunkId    String
  documentId String
  similarity Float
  rank       Int
  createdAt  DateTime @default(now())
  event      RAGEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([documentId])
  @@map("retrieved_chunks")
}

model Metric {
  id        String   @id @default(cuid())
  type      String
  value     Float
  labels    Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([type])
  @@index([timestamp])
  @@map("metrics")
}

model IntegrationAccount {
  id                String    @id @default(cuid())
  provider          String
  providerAccountId String
  accessToken       String
  refreshToken      String?
  expiresAt         DateTime?
  scope             String?
  userId            String
  workspaceId       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("integration_accounts")
}

model Experiment {
  id                String           @id @default(cuid())
  name              String
  description       String?
  type              String
  status            ExperimentStatus @default(DRAFT)
  variants          Json
  trafficAllocation Json
  workspaceId       String
  createdById       String
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@map("experiments")
}

model ExperimentEvent {
  id           String   @id @default(cuid())
  experimentId String
  variantId    String
  eventType    String
  userId       String?
  sessionId    String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([experimentId])
  @@index([variantId])
  @@map("experiment_events")
}

model SamlConnection {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  idpMetadata       String?
  idpEntityId       String?
  idpSsoUrl         String?
  idpSloUrl         String?
  idpCertificate    String?
  spEntityId        String    @default("rag-starter-kit")
  spAcsUrl          String?
  publicCertificate String?
  privateKey        String?
  allowIdpInitiated Boolean   @default(false)
  defaultRole       String    @default("MEMBER")
  attributeMapping  Json      @default("{}")
  enabled           Boolean   @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([enabled])
  @@map("saml_connections")
}

model Webhook {
  id              String            @id @default(cuid())
  name            String
  url             String
  secret          String
  events          String[]
  status          WebhookStatus     @default(ACTIVE)
  workspaceId     String
  createdById     String
  lastTriggeredAt DateTime?
  failureCount    Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deliveries      WebhookDelivery[]

  @@index([workspaceId])
  @@index([status])
  @@map("webhooks")
}

model WebhookDelivery {
  id          String         @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?
  error       String?
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  durationMs  Int?
  status      DeliveryStatus @default(PENDING)
  retryCount  Int            @default(0)
  webhook     Webhook        @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([startedAt])
  @@map("webhook_deliveries")
}

model Consent {
  id          String    @id @default(cuid())
  userId      String
  consentType String
  granted     Boolean
  grantedAt   DateTime  @default(now())
  revokedAt   DateTime?
  version     String    @default("1.0")
  ipAddress   String?
  userAgent   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
  @@index([userId, consentType])
  @@map("consents")
}

enum UserRole {
  USER
  ADMIN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REMOVED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ErrorCategory {
  PARSE_ERROR
  EMBEDDING_ERROR
  SIZE_LIMIT
  OCR_FAILURE
  PROVIDER_ERROR
  NETWORK_ERROR
  UNKNOWN
}

enum ImageStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

enum FeedbackRating {
  UP
  DOWN
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditEvent {
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTERED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  WORKSPACE_SETTINGS_CHANGED
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  DOCUMENT_UPDATED
  DOCUMENT_PROCESSED
  DOCUMENT_PROCESSING_FAILED
  CHAT_CREATED
  CHAT_UPDATED
  CHAT_DELETED
  CHAT_MESSAGE_SENT
  API_KEY_CREATED
  API_KEY_REVOKED
  API_KEY_USED
  RATE_LIMIT_HIT
  SUSPICIOUS_ACTIVITY
  PERMISSION_DENIED
  AGENT_QUERY_CLASSIFIED
  AGENT_TOOL_CALLED
  MULTI_STEP_REASONING_STARTED
  CONVERSATION_BRANCHED
  VOICE_TRANSCRIPTION
  READ_API_USAGE
  ENCRYPTION_OPERATION
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}
