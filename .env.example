# APPLICATION
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:7392
NEXT_TELEMETRY_DISABLED=1
LOG_LEVEL=info

# AI — OpenRouter (chat, all LLM calls)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# AI — Google Gemini (embeddings only)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-gemini-api-key-here
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=768

# AI — Groq (floating chatbot widget only)
GROQ_API_KEY=gsk_your-groq-key-here

# AI — Cohere (reranker only)
COHERE_API_KEY=your-cohere-api-key-here

# AUTH (NextAuth v5)
NEXTAUTH_SECRET=generate-a-32-character-secret-key-here
NEXTAUTH_URL=http://localhost:7392
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# DATABASE (Prisma Accelerate + Neon)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY
DIRECT_URL=postgresql://user:password@your-db-host/ragdb?sslmode=require

# STORAGE (Cloudinary)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# REDIS (Upstash)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# BACKGROUND JOBS (Inngest)
INNGEST_SIGNING_KEY=dev-signing-key-change-in-production
INNGEST_EVENT_KEY=dev-event-key-change-in-production

# REALTIME (Ably)
ABLY_API_KEY=your-ably-api-key

# SECURITY
ENCRYPTION_MASTER_KEY=change-this-to-a-32-character-key-for-production
ALLOWED_ORIGINS=http://localhost:7392

# EMAIL (Resend)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=your-email@example.com
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret

# VECTOR DATABASE (Qdrant Cloud)
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# RERANKER (Cohere)
RERANKER_ENABLED=true
RERANKER_PROVIDER=cohere
