# ============================================
# RAG Starter Kit - Environment Configuration
# ============================================
#
# QUICK START:
# 1. Copy this file to .env: cp .env.example .env
# 2. Get your FREE API keys (links below)
# 3. Run: pnpm dev
#
# DEPLOYMENT:
# For Vercel Hobby plan deployment, see docs/deployment/vercel-hobby.md
#
# ============================================

# ============================================
# REQUIRED — Free Tier
# ============================================

# OpenRouter — LLM chat (free models available)
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Google Gemini — Vector embeddings (FREE: 1,500 req/day)
# Sign up: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-gemini-api-key-here

# Authentication — JWT signing secret
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-32-character-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Database — Neon serverless PostgreSQL with pgvector
# Create free DB: https://console.neon.tech
# After creating, run: CREATE EXTENSION IF NOT EXISTS vector;
# IMPORTANT: Use the pooled connection string (ends with -pooler) for DATABASE_URL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/ragdb?sslmode=require

# ============================================
# STRONGLY RECOMMENDED — Free Tier
# ============================================

# Redis — Upstash serverless (caching, rate limiting, degradation flags)
# Create free: https://console.upstash.com
# Without Redis: rate limiting falls back to database (slower but functional)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Background Jobs — Inngest (document processing pipeline)
# Local dev: pnpm inngest:dev
# Production: https://www.inngest.com (free tier available)
INNGEST_SIGNING_KEY=dev-signing-key-change-in-production
INNGEST_EVENT_KEY=dev-event-key-change-in-production

# File Storage — Cloudinary (document uploads)
# Free tier: 25GB storage, 25K transformations/month
# Sign up: https://cloudinary.com/users/register_free
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=rag-starter-kit

# ============================================
# OPTIONAL — Enhanced Features
# ============================================

# Error Tracking — Sentry (free: 5K events/month)
# Sign up: https://sentry.io → create Next.js project
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Re-ranking — Cohere (improves retrieval quality)
# RERANKER_ENABLED=true
# RERANKER_PROVIDER=cohere
# COHERE_API_KEY=your-cohere-api-key

# Real-time — Ably (typing indicators, presence, cursors)
# ABLY_API_KEY=your-ably-api-key

# Email — Resend (alerts, notifications)
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_TO_EMAIL=your-email@example.com

# Analytics — Plausible (privacy-focused)
# NEXT_PUBLIC_ANALYTICS_HOST=https://plausible.io
# NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=https://plausible.io/js/script.js
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# ============================================
# OPTIONAL — Additional LLM Providers
# ============================================

# All below have free tiers. The app falls back through these automatically.
# GROQ_API_KEY=gsk_your-groq-key-here
# NVIDIA_API_KEY=nvapi-your-nvidia-key-here
# CEREBRAS_API_KEY=csk-your-cerebras-key-here
# SAMBANOVA_API_KEY=sk-your-sambanova-key-here
# MISTRAL_API_KEY=sk-your-mistral-key-here
# FIREWORKS_API_KEY=fw_your-fireworks-key-here

# ============================================
# OPTIONAL — OAuth Providers
# ============================================

# AUTH_GITHUB_ID=your-github-oauth-app-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-secret
# AUTH_GOOGLE_ID=your-google-oauth-client-id
# AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ============================================
# OPTIONAL — Advanced Configuration
# ============================================

# Security (REQUIRED for production)
# ENCRYPTION_MASTER_KEY=change-this-to-a-32-character-key-for-production

# Database tuning
# DB_POOL_MAX=5
# HNSW_EF_SEARCH=40

# Embedding tuning
# EMBEDDING_PROVIDER=google
# EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_DIMENSIONS=768

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# Default model override
# DEFAULT_MODEL=deepseek/deepseek-chat:free
# LLM_PROVIDER=openrouter
